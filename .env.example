# ============================================================
# AgentBloom Environment Variables
# Copy to .env and fill in values for your environment
# ============================================================

# ── Django Core ──────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (PostgreSQL + pgvector) ─────────────────────────
DATABASE_URL=postgresql://agentbloom:agentbloom@db:5432/agentbloom

# ── Redis (cache, sessions, Channels, Celery) ───────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# ── CORS ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── AWS (S3, SES, CloudFront) ───────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET_ASSETS=agentbloom-assets
AWS_S3_BUCKET_SITES=agentbloom-sites
AWS_CLOUDFRONT_DOMAIN=

# ── AWS SES (Email) ─────────────────────────────────────────
AWS_SES_REGION=us-east-1
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── LLM API Keys ────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=

# ── Google OAuth (django-allauth social login) ──────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Unsplash (stock photos for site builder) ────────────────
UNSPLASH_ACCESS_KEY=

# ── Frontend URL (used for Stripe return URLs, emails, etc.) ─
FRONTEND_URL=http://localhost:3000

# ── Next.js Frontend ────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
