# AgentBloom Backend Environment Variables
# Copy to .env and fill in values

# Django
DJANGO_SECRET_KEY=change-me-to-a-real-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,agentbloom.nobleblocks.com
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgres://agentbloom:password@localhost:5432/agentbloom

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET_ASSETS=agentbloom-assets
AWS_S3_BUCKET_SITES=agentbloom-sites
AWS_CLOUDFRONT_DOMAIN=

# SES
AWS_SES_REGION=us-east-1
DEFAULT_FROM_EMAIL=noreply@nobleblocks.com

# LLM APIs
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Unsplash (Stock Images)
UNSPLASH_ACCESS_KEY=

# Deepgram (Transcription)
DEEPGRAM_API_KEY=

# ElevenLabs (TTS)
ELEVENLABS_API_KEY=

# Frontend URL
FRONTEND_URL=http://localhost:3000
